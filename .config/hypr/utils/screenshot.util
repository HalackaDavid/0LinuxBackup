#!/bin/zsh

screenshotPath="$NCORMediaPath/Screenshots"
scname="$screenshotPath/$(date +'%d.%m.%Y-%Hh%Mm%Ss_%3N').png"

case $1 in
    "1")
        grim "$screenshotPath/$scname
        ;;

    "2")
        grim -g "$(slurp)" "$screenshotPath/$scname
        ;;
esac

unset screenshotPath
unset scname
