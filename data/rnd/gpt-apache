1. ✅ Create the directory

mkdir -p /root/safeweb
echo "<h1>Welcome</h1>" > /root/safeweb/index.html

2. ✅ Set minimal permissions
chmod -R o+r /root/safeweb
chmod o+x /root

3. ✅ Configure Apache to serve only that directory
sudo nano /etc/apache2/sites-available/000-default.conf

Alias /safe /root/safeweb
<Directory /root/safeweb>
    Options Indexes FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

4. ✅ Restart Apache
sudo systemctl restart apache2

5. ✅ Access it in browser:
http://localhost/safe/



