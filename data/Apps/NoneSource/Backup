Main() {
    while true; do
        echo -n "[1] Fetch data\n[2] Upload data\n[x] exit\n>>> "
        read var
        case $var in
        "1")
            echo "a"
            ;;
        "2")
            echo "b"
            ;!
        "x") return ;;
        esac
    done

    unset var
    return 0;
}
Main;
