#!/bin/zsh

Foo() {
    for i in $@; do
        case $i in
            "0") git stash push -u && git pull --rebase && git stash pop || true;;
            "1") git status;;
            "2") git add . && git commit -m "$(TZ="Europe/Prague" date +"%d.%m.%Y-%Hh%Mm%Ss")";;
            "3") git push;;
        esac
    done
    unset i

}

Main() {
    (
        cd ~
        
        if [[ ! ${#@} -eq 0 ]]; then 
            chars=(${(s::)1})
            Foo $chars
            unset chars
            return;
        fi

        print -n "NO ARGS PASSED\n0 -> fetch\n1 -> status\n2 -> commit all\n3 -> push\n"
    )
}
Main $1
