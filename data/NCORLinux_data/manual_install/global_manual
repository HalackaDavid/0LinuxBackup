11. SYSTEMD-BOOT (UEFI)
------------------------------------------------------------
bootctl install

#it is for ncor.conf (variables are with arrow braces '<' and '>' anyhing else is as it is typed)
<ROOT_UUID>=$(lsblk -o PARTUUID /dev/<DISKNAME>)
<BOOT_NAME>=ncor

#inside /boot/loader/loader.conf
------------------------
default <BOOT_NAME>
timeout 3
editor no

#inside /boot/loader/entries/<BOOT_NAME>.conf
-------------------------------
title   NCOR
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=PARTUUID=<ROOT_UUID> rw

reboot to the os


#if tty will be using some loglevels add to options loglevel=3
# loglevel options but you want 3 mostly
```
0 = only emergency
1 = alert
2 = critical
3 = errors
4 = warnings (default-ish)
5 = notice
6 = info
7 = debug (very noisy)
```

# whole file should look like
#inside /boot/loader/entries/<BOOT_NAME>.conf
-------------------------------
title   NCOR
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=PARTUUID=<ROOT_UUID> rw loglevel=3


