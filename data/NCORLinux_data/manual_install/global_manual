------------------------------------------------------------
1. LIVE ISO PREP
------------------------------------------------------------
setfont ter-132n #For live iso to make bigger text only after reboot gone 
timedatectl set-ntp true

Verify UEFI:
ls /sys/firmware/efi/efivars

------------------------------------------------------------
2. MIRRORS AND PACMAN CONFIG
------------------------------------------------------------
# Ensure core, extra, community repos enabled

vim /etc/pacman.conf

# Uncomment:
[core]
Include = /etc/pacman.d/mirrorlist

[extra]
Include = /etc/pacman.d/mirrorlist

#Comunity may be required
[community]
Include = /etc/pacman.d/mirrorlist

pacman -Sy

------------------------------------------------------------
3. DISK PARTITIONING (GPT)
------------------------------------------------------------
parted /dev/<TARGET_DISK>
- mklabel gpt
- mkpart ESP fat32 1MiB 1025MiB
- set 1 esp on
- mkpart primary ext4 1025MiB 100%
- quit

------------------------------------------------------------
4. FILESYSTEMS
------------------------------------------------------------
mkfs.fat -F32 /dev/<TARGET_DISK>1
mkfs.ext4 /dev/<TARGET_DISK>2

mount /dev/<TARGET_DISK>2 /mnt
mkdir /mnt/boot
mount /dev/<TARGET_DISK>1 /mnt/boot

------------------------------------------------------------
5. BASE INSTALL
------------------------------------------------------------
pacstrap /mnt \
  base linux linux-headers linux-firmware \
  efibootmgr dosfstools \
  dhcpcd iwd pipewire pipewire-pulse pipewire-alsa wireplumber mesa /
  xdg-desktop-portal xdg-desktop-portal-wlr \
  hyprland wl-clipboard wofi swaybg hyprlock brightnessctl foot foot-terminfo \
  dolphin kdegraphics-thumbnailers kimageformats ffmpegthumbs ark \
  sudo git neovim zsh tmux man-db man-pages less htop curl wget rsync unzip zip tar openssh tree viu xplr

------------------------------------------------------------
6. FSTAB
------------------------------------------------------------
genfstab -U /mnt >> /mnt/etc/fstab

------------------------------------------------------------
7. CHROOT
------------------------------------------------------------
arch-chroot /mnt

------------------------------------------------------------
8. TIME / LOCALE / HOST
------------------------------------------------------------
ln -sf /usr/share/zoneinfo/<REGION>/<CITY> /etc/localtime
hwclock --systohc

Edit /etc/locale.gen:
- uncomment: en_US.UTF-8 UTF-8
locale-gen

echo "LANG=en_US.UTF-8" > /etc/locale.conf
#HOSTNAME in my case ncor
echo "<HOSTNAME>" > /etc/hostname

------------------------------------------------------------
9. NETWORKING
------------------------------------------------------------
# Ethernet works automatically
# Wi-Fi via: iwctl
# sudo systemctl start iwd will bypass systemd passwd

systemctl enable dhcpcd
systemctl enable iwd

------------------------------------------------------------
10. USERS & SECURITY
------------------------------------------------------------
passwd   # set root password temporarily
useradd -m -G wheel -s /bin/zsh <USERNAME>
passwd <USERNAME>

in /etc/sudoers
- Uncomment: %wheel ALL=(ALL:ALL) ALL

# Optional: disable root login
passwd -l root

------------------------------------------------------------
11. SYSTEMD-BOOT (UEFI)
------------------------------------------------------------
bootctl install

#it is for ncor.conf (variables are with arrow braces '<' and '>' anyhing else is as it is typed)
<ROOT_UUID>=$(lsblk -o PARTUUID /dev/<DISKNAME>)
<BOOT_NAME>=ncor

#inside /boot/loader/loader.conf
------------------------
default <BOOT_NAME>
timeout 3
editor no

#inside /boot/loader/entries/<BOOT_NAME>.conf
-------------------------------
title   NCOR
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=PARTUUID=<ROOT_UUID> rw

reboot to the os

